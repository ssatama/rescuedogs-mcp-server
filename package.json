{
  "name": "rescuedogs-mcp-server",
  "version": "1.2.0",
  "description": "MCP server for discovering rescue dogs from European and UK organizations",
  "main": "dist/index.js",
  "bin": {
    "rescuedogs-mcp-server": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "rescue-dogs",
    "dog-adoption",
    "claude",
    "llm",
    "model-context-protocol"
  ],
  "author": "Sampo Satama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssatama/rescuedogs-mcp-server.git"
  },
  "homepage": "https://www.rescuedogs.me",
  "bugs": {
    "url": "https://github.com/ssatama/rescuedogs-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.15.1",
    "node-cache": "^5.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
